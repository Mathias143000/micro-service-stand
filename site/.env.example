# Spring backend runtime variables
SERVER_PORT=8080

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/realestate
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# App security
APP_JWT_SECRET=0123456789abcdef0123456789abcdef
APP_JWT_EXPIRATION_MINUTES=1440

# Files and seed data
APP_FILES_STORAGE_DIR=./uploads
APP_DEMO_USERS_ENABLED=true
